#!/usr/bin/env bash
# Runs during the Python buildpack compile step (after packages are installed,
# after the Node.js buildpack has already built the React app).
# Files created here are baked into the slug and available to the web dyno.
set -e

# Derive app root from this script's own location regardless of how the
# buildpack calls it (sourced or exec, with or without $1).
APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." && pwd)"

echo "-----> Running collectstatic (bin/post_compile)"
cd "$APP_ROOT/backend"
python manage.py collectstatic --noinput
echo "-----> collectstatic complete"
